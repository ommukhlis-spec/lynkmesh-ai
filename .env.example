# LynkMesh AI -- Environment Configuration
# Copy this file to .env and customize for your environment.
#
# LynkMesh AI uses zero external services by default.
# All analysis runs locally on the Python stdlib.
# No API keys or remote credentials are required.
#
# Future integrations (optional):
#   CLAUDE_API_KEY=     # For direct Claude API integration (not yet implemented)
#   GITHUB_TOKEN=       # For PR/issue integration (not yet implemented)
#   LOG_LEVEL=INFO      # DEBUG, INFO, WARNING, ERROR
